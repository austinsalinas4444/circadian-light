# CircadianLight Backend — Environment Configuration
# Copy to .env and fill in values. Never commit .env to version control.

# --- Supabase ---
SUPABASE_URL=
SUPABASE_KEY=

# --- ML Model ---
# Set to "true" to use CircadianNet for recommendations (falls back to policy on failure)
USE_ML_MODEL=false

# --- Circadian Anchors ---
# Override the default wake/sleep times used by the policy
WAKE_TIME=8
SLEEP_TIME=24
